{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "notesApp",
  "version": "1.0.0",
  "identifier": "com.joeydeveloper.notesapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1100,
        "height": 720,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 12, "y": 14 },
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/joeygrecodeveloper/notesApp/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwQzdCOTVCNEM1Q0ExRTQKUldUa29WeE1XN25IMEpERXRNb1ZsVE94UmtLV1Q0eWxhcG11bFBUckRZRUo4amd1NndIaUY0SEwK"
    }
  }
}
